# Get these from https://my.telegram.org → API development tools
API_ID=your_api_id
API_HASH=your_api_hash
# Your Telegram account phone (with country code, e.g. +1234567890)
PHONE=+your_phone_number

# Optional: Railway (or any) PostgreSQL. When set, viewer and extractor use DB instead of files.
# DATABASE_URL=postgresql://user:password@host:port/railway

# ── Rate Limiting (see SCRAPER_RULES.md) ──
# DELAY_BETWEEN_API_CALLS=1.2
# DELAY_BETWEEN_CHANNELS_MIN=5
# DELAY_BETWEEN_CHANNELS_MAX=10
# FLOOD_WAIT_BUFFER=5
# MAX_FLOOD_WAITS_PER_HOUR=5
# PAUSE_AFTER_N_CHANNELS=25
# PAUSE_DURATION_MIN=120
# PAUSE_DURATION_MAX=300
# SKIP_RECENTLY_SCRAPED_HOURS=24
